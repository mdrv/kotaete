---
interface Props {
	title?: string
}

const { title = '@mdrv/kotaete docs' } = Astro.props
---

<!DOCTYPE html>
<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<title>{title}</title>
		<style>
		* {
			box-sizing: border-box;
			margin: 0;
			padding: 0;
		}
		body {
			font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
			line-height: 1.6;
			color: #1a1a1a;
			max-width: 860px;
			margin: 0 auto;
			padding: 2rem 1rem;
		}
		a {
			color: #0066cc;
			text-decoration: none;
		}
		a:hover {
			text-decoration: underline;
		}
		h1 {
			font-size: 1.8rem;
			margin-bottom: 0.5rem;
			padding-bottom: 0.5rem;
			border-bottom: 2px solid #eaeaea;
		}
		h2 {
			font-size: 1.4rem;
			margin-top: 2rem;
			margin-bottom: 0.5rem;
		}
		code {
			background: #f4f4f4;
			padding: 0.15rem 0.35rem;
			border-radius: 3px;
			font-size: 0.9em;
		}
		pre {
			background: #f4f4f4;
			padding: 1rem;
			border-radius: 6px;
			overflow-x: auto;
			margin: 1rem 0;
		}
		pre code {
			background: none;
			padding: 0;
		}
		hr {
			border: none;
			border-top: 1px solid #eaeaea;
			margin: 2rem 0;
		}
		nav {
			margin-bottom: 1.5rem;
		}
		nav a {
			margin-right: 1rem;
		}
		ul {
			padding-left: 1.5rem;
		}
		li {
			margin: 0.25rem 0;
		}
		</style>
	</head>
	<body>
		<nav>
			<a href='/'>Home</a>
			<a href='/docs/baileys-linking-fix-guide'>Baileys Guide</a>
			<a href='/markdown/'>Raw Markdown</a>
		</nav>
		<main>
			<slot />
		</main>
	</body>
</html>
