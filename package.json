{
	"name": "nipbang-kotaete",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"engines": {
		"bun": ">=1.3"
	},
	"bin": {
		"kotaete": "./src/cli/index.ts"
	},
	"scripts": {
		"dev": "bun run src/cli/index.ts",
		"daemon": "bun run src/cli/index.ts daemon",
		"daemon:baileys": "bun run baileys:patch:check && bun run src/cli/index.ts daemon --provider baileys",
		"baileys:patch": "bun run scripts/patch-baileys-linking.ts",
		"baileys:patch:check": "bun run scripts/patch-baileys-linking.ts --check",
		"test": "bun test",
		"fmt": "dprint fmt",
		"fmt:check": "dprint check",
		"typecheck": "bun tsc --noEmit",
		"check": "bun run fmt:check && bun run typecheck"
	},
	"dependencies": {
		"@crustjs/core": "^0.0.15",
		"@crustjs/plugins": "^0.0.20",
		"@logtape/logtape": "^2.0.5",
		"@logtape/pretty": "^2.0.5",
		"@whiskeysockets/baileys": "github:WhiskeySockets/Baileys#d077902",
		"pino": "^10.3.1",
		"qrcode-terminal": "^0.12.0",
		"whatsapp-web.js": "^1.34.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/qrcode-terminal": "^0.12.2",
		"dprint": "^0.53.2"
	},
	"trustedDependencies": [
		"@whiskeysockets/baileys",
		"protobufjs"
	]
}
